# Environment variables for development
# Copy this file to .env.local and fill in your actual keys

# Clerk Authentication
# Demo keys below work for builds but won't enable real authentication
# Get production keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase Database
# Required for data persistence - get from: https://supabase.com/dashboard
# Run the supabase.sql migration script in your Supabase SQL editor first
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=public-anonymous-key

# Sentry Error Monitoring (Optional but recommended for production)
# Get from: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-org-name
SENTRY_PROJECT=your-project-name
# Auth token for uploading source maps (only needed in CI/CD)
SENTRY_AUTH_TOKEN=your_auth_token_here

# Anthropic Claude AI Agent
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
