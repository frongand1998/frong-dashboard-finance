# Environment variables for development
# Copy this file to .env.local and fill in your actual keys

# Clerk Authentication
# Get keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase Database
# Get keys from: https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Recurring cron endpoint secret
# Used by POST /api/recurring/run with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Sentry Error Monitoring (optional)
# Get values from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# AI Agent provider
# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Feedback to Google Sheets (Google Apps Script Web App URL)
# Example: https://script.google.com/macros/s/AKfycb.../exec
GOOGLE_APPS_SCRIPT_URL=
